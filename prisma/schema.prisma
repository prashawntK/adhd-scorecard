generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User (synced with Supabase Auth) ───────────────────────────────────────

model User {
  id        String   @id // Supabase Auth UUID — set on creation, not auto-generated
  email     String   @unique
  name      String?
  avatarUrl String?

  plan             String  @default("free") // "free" | "pro" | "lifetime"
  stripeCustomerId String? @unique

  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals            Goal[]
  dailyLogs        DailyLog[]
  timerSessions    TimerSession[]
  streaks          Streak[]
  steps            Step[]
  dailyScores      DailyScore[]
  rewards          Reward[]
  pointsLedger     PointsLedger[]
  journalEntries   JournalEntry[]
  energyLogs       EnergyLog[]
  extraCurriculars ExtraCurricular[]
  ecLogs           ExtraCurricularLog[]
  ecTimeLogs       ExtraCurricularTimeLog[]
  chores           Chore[]
  choreTimeLogs    ChoreTimeLog[]
  choreCompletions ChoreCompletionLog[]
  settings         AppSettings?
}

// ─── Goals & Tracking ───────────────────────────────────────────────────────

model Goal {
  id          String   @id @default(cuid())
  userId      String?  // optional until auth is wired up (Task 4)
  name        String
  emoji       String   @default("🎯")
  category    String   // "Learning" | "Career" | "Health" | "Personal" | "Creative"
  description String?
  motivation  String?

  goalType    String   @default("timer") // "timer" | "checkbox"
  dailyTarget Float    @default(0)       // hours for timer goals, 0 for checkbox

  priority    String   @default("should") // "must" | "should" | "want"

  activeDays       Json  @default("[1,2,3,4,5,6,0]") // [0=Sun,1=Mon,...,6=Sat]
  pomodoroSettings Json? // { enabled, workMinutes, breakMinutes }

  sortOrder  Int      @default(0)
  isArchived Boolean  @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLogs     DailyLog[]
  timerSessions TimerSession[]
  streaks       Streak[]
  steps         Step[]

  @@index([userId])
  @@index([userId, isArchived])
  @@index([isArchived])
  @@index([category])
}

model DailyLog {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  goalId String
  date   String  // "YYYY-MM-DD"

  completed    Boolean @default(false)
  timeSpent    Float   @default(0)   // hours
  targetAtTime Float   @default(0)   // snapshot of dailyTarget at log time
  focusRating  Float?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([userId])
  @@index([date])
  @@index([goalId])
}

model TimerSession {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  goalId String
  date   String  // "YYYY-MM-DD"

  startTime DateTime
  endTime   DateTime?
  duration  Float    @default(0) // hours

  sessionType String  @default("focus") // "focus" | "pomodoro_work" | "pomodoro_break" | "manual"
  focusRating Int?
  isActive    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stepId String?
  step   Step?   @relation(fields: [stepId], references: [id], onDelete: SetNull)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId, date])
  @@index([isActive])
  @@index([date])
  @@index([stepId])
}

model Streak {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  goalId String? // null = overall app streak

  currentStreak  Int     @default(0)
  longestStreak  Int     @default(0)
  lastActiveDate String?

  freezesUsedThisWeek Int     @default(0)
  lastFreezeDate      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal?  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  // goalId alone is still unique (existing single-user data has one streak per goal)
  @@unique([goalId])
  @@index([userId])
}

model Step {
  id          String    @id @default(cuid())
  userId      String?   // optional until auth is wired up (Task 4)
  goalId      String
  name        String
  sortOrder   Int       @default(0)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal          Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  timerSessions TimerSession[]

  @@index([userId])
  @@index([goalId, sortOrder])
  @@index([goalId])
}

// ─── Scoring & Gamification ─────────────────────────────────────────────────

model DailyScore {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  date   String  // "YYYY-MM-DD"

  score          Float @default(0)
  goalsCompleted Int   @default(0)
  goalsTotal     Int   @default(0)
  totalHours     Float @default(0)
  targetHours    Float @default(0)
  streakBonus    Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Keep date unique for now (single user); will become @@unique([userId, date]) in Task 4
  @@unique([date])
  @@index([userId])
  @@index([date])
}

model Reward {
  id          String  @id @default(cuid())
  userId      String? // optional until auth is wired up (Task 4)
  name        String
  emoji       String  @default("🎁")
  description String?
  cost        Int
  category    String  @default("treat") // "treat" | "activity" | "purchase" | "social"

  timesRedeemed Int       @default(0)
  lastRedeemed  DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PointsLedger {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  amount Int
  reason String
  detail String?
  date   String  // "YYYY-MM-DD"

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─── Wellbeing ──────────────────────────────────────────────────────────────

model JournalEntry {
  id      String  @id @default(cuid())
  userId  String? // optional until auth is wired up (Task 4)
  date    String  // "YYYY-MM-DD"
  content String
  mood    Int?    // 1-5

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Keep date unique for now (single user); will become @@unique([userId, date]) in Task 4
  @@unique([date])
  @@index([userId])
  @@index([date])
}

model EnergyLog {
  id     String  @id @default(cuid())
  userId String? // optional until auth is wired up (Task 4)
  date   String
  time   String  // "HH:MM"
  level  Int     // 1-5
  note   String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─── Extra-Curriculars ──────────────────────────────────────────────────────

model ExtraCurricular {
  id            String    @id @default(cuid())
  userId        String?   // optional until auth is wired up (Task 4)
  name          String
  emoji         String    @default("✨")
  sortOrder     Int       @default(0)
  targetMinutes Int?      // recommended session duration in minutes
  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs     ExtraCurricularLog[]
  timeLogs ExtraCurricularTimeLog[]

  @@index([userId])
  @@index([isArchived])
}

model ExtraCurricularLog {
  id                String   @id @default(cuid())
  userId            String?  // optional until auth is wired up (Task 4)
  extraCurricularId String
  date              String   // "YYYY-MM-DD"
  completed         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  extraCurricular ExtraCurricular @relation(fields: [extraCurricularId], references: [id], onDelete: Cascade)

  @@unique([extraCurricularId, date])
  @@index([userId])
  @@index([date])
  @@index([extraCurricularId])
}

model ExtraCurricularTimeLog {
  id                String   @id @default(cuid())
  userId            String?  // optional until auth is wired up (Task 4)
  extraCurricularId String
  date              String   // "YYYY-MM-DD"
  minutesSpent      Int
  createdAt         DateTime @default(now())

  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  extraCurricular ExtraCurricular @relation(fields: [extraCurricularId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([extraCurricularId])
  @@index([date])
}

// ─── Chores ─────────────────────────────────────────────────────────────────

model Chore {
  id               String    @id @default(cuid())
  userId           String?   // optional until auth is wired up (Task 4)
  name             String
  emoji            String    @default("🧹")
  deadline         DateTime
  estimatedMinutes Int       @default(30)
  description      String?
  sortOrder        Int       @default(0)
  isArchived       Boolean   @default(false)
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeLogs       ChoreTimeLog[]
  completionLogs ChoreCompletionLog[]

  @@index([userId])
  @@index([isArchived])
  @@index([deadline])
}

model ChoreTimeLog {
  id           String   @id @default(cuid())
  userId       String?  // optional until auth is wired up (Task 4)
  choreId      String
  date         String   // "YYYY-MM-DD"
  minutesSpent Int
  createdAt    DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chore Chore  @relation(fields: [choreId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([choreId])
  @@index([date])
}

model ChoreCompletionLog {
  id        String   @id @default(cuid())
  userId    String?  // optional until auth is wired up (Task 4)
  choreId   String
  date      String   // "YYYY-MM-DD"
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chore Chore  @relation(fields: [choreId], references: [id], onDelete: Cascade)

  @@unique([choreId, date])
  @@index([userId])
  @@index([date])
  @@index([choreId])
}

// ─── Settings ───────────────────────────────────────────────────────────────

model AppSettings {
  id     String  @id @default(cuid())
  userId String? @unique // optional until auth is wired up (Task 4)

  theme String @default("dark") // "dark" | "light"

  weeklyFreezeLimit Int @default(2)

  soundEnabled Boolean @default(true)
  soundVolume  Float   @default(0.5)

  defaultWorkMinutes  Int @default(25)
  defaultBreakMinutes Int @default(5)

  hyperfocusGuardMinutes Int     @default(120)
  hyperfocusGuardEnabled Boolean @default(true)

  pointsPerGoalComplete Int @default(10)
  pointsPerStreakDay     Int @default(5)
  pointsBonusPerfectDay Int @default(25)

  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
